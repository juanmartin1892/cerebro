# Variables de entorno — Local (estación de trabajo, desarrollo)
# Copiar a local.env y rellenar los valores reales
# NUNCA subir local.env a git

LOG_LEVEL=DEBUG

# === Telegram ===
# Usar un bot de pruebas distinto al de producción
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# === LLM ===
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=

# === Rutas ===
# VAULT_PATH=/home/user/vault
# SCRIPTS_LOG_DIR=/tmp/cerebro-logs
